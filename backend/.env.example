# ============================================
# FILE: .env.example
# ============================================
# ============================================
# ENGINEERING DOCUMENTATION PORTAL - ENV CONFIG
# Copy this to .env and fill in your values
# ============================================

# Application
APP_NAME=Engineering Documentation Portal
APP_VERSION=1.0.0
DEBUG=True

# Database
# Format: mysql://username:password@host:port/database
DATABASE_URL=mysql://root:your_password@localhost:3306/engineering_portal

# Security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-generated-with-command-above
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=[".pdf",".docx",".doc",".md",".txt",".xlsx",".pptx"]

# CORS - Add your frontend URLs
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080"]

# Email (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourcompany.com